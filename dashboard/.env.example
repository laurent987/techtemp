# Copy to .env.local and adjust for your setup.

# Backend base URL (TechTemp API). Defaults to http://192.168.0.42:3000/api/v1.
# VITE_API_BASE_URL=http://192.168.0.42:3000/api/v1

# Outdoor weather location for the Open-Meteo overlay. Defaults to Leuven, BE.
# VITE_WEATHER_LAT=50.8798
# VITE_WEATHER_LON=4.7005
# VITE_WEATHER_TZ=Europe/Brussels
