# Copy to .env.local and adjust for your setup.

# Backend base URL (TechTemp API). Defaults to http://192.168.0.42:3000/api/v1.
# REACT_APP_API_BASE_URL=http://192.168.0.42:3000/api/v1

# Override the dev server port (default 3000). Useful when port 3000 is taken.
# PORT=3001

# Outdoor weather location for the Open-Meteo overlay. Defaults to Leuven, BE.
# REACT_APP_WEATHER_LAT=50.8798
# REACT_APP_WEATHER_LON=4.7005
# REACT_APP_WEATHER_TZ=Europe/Brussels
